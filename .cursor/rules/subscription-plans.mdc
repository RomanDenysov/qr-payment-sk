### Clerk Integration
```typescript
// Stripe Product IDs
const STRIPE_PRODUCTS = {
  business: 'prod_business_monthly',
  professional: 'prod_professional_monthly'
} as const

// Feature Gates in Clerk
const CLERK_PLAN_FEATURES = {
  business: ['5_templates', '1000_qr_monthly', 'bulk_generation', 'advanced_analytics'],
