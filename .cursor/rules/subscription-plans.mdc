## 🎯 Plan Implementation Helpers

### Plan Detection
```typescript
export function getUserPlan(user: any): 'starter' | 'business' | 'professional' {
  if (user?.has?.('unlimited_templates')) return 'professional'
  if (user?.has?.('5_templates')) return 'business'
  return 'starter'
}
```

### Feature Availability Check
```typescript
export function isFeatureAvailable(
  plan: string, 
  feature: keyof PlanConfig
): boolean {
  const planConfig = getPlanConfig(plan)
  return planConfig[feature] === true || planConfig[feature] === -1
}
```

### Upgrade Prompts
```typescript
export function getUpgradeTarget(
  currentPlan: string,
  desiredFeature: string
): 'business' | 'professional' | null {
  if (currentPlan === 'starter') {
    if (BUSINESS_FEATURES.includes(desiredFeature)) return 'business'
    if (PROFESSIONAL_FEATURES.includes(desiredFeature)) return 'professional'
  }
  
  if (currentPlan === 'business') {
    if (PROFESSIONAL_FEATURES.includes(desiredFeature)) return 'professional'
  }
  
  return null
}
```

