## 🎯 Clerk Permission Hooks

### 1. Enhanced usePermissions Hook
```typescript
// hooks/usePermissions.ts
import { useHas, useUser } from '@clerk/nextjs'

export function usePermissions() {
  const { has, isLoaded } = useHas()
  const { user, isLoaded: userLoaded } = useUser()
  
  if (!isLoaded || !userLoaded) {
    return {
      isLoading: true,
      permissions: {},
      plan: 'starter',
      hasFeature: () => false
    }
  }
  
  const plan = getPlanFromFeatures(has)
  
  const permissions = {
    // Template permissions
    canCreateTemplate: has('5_templates') || has('unlimited_templates'),
    canDuplicateTemplate: has('5_templates') || has('unlimited_templates'),
    canShareTemplate: has('5_templates') || has('unlimited_templates'),
    canCollaborateTemplate: has('unlimited_templates'),
    maxTemplates: has('unlimited_templates') ? -1 : (has('5_templates') ? 5 : 1),
    
    // QR Generation permissions
    canBulkGenerate: has('bulk_generation'),
    canScheduleGeneration: has('unlimited_qr'),
    canCustomizeQR: has('5_templates') || has('unlimited_templates'),
    canGenerateDynamic: has('5_templates') || has('unlimited_templates'),
    monthlyQRLimit: has('unlimited_qr') ? -1 : (has('1000_qr_monthly') ? 1000 : 50),
    maxBulkSize: has('unlimited_qr') ? 1000 : (has('bulk_generation') ? 50 : 0),
    
    // Analytics permissions
    canViewDetailedStats: has('advanced_analytics'),
    canExportAnalytics: has('advanced_analytics'),
    canCreateReports: has('unlimited_templates'),
    canScheduleReports: has('unlimited_templates'),
    canSetupAlerts: has('unlimited_templates'),
    analyticsHistoryDays: has('unlimited_templates') ? -1 : (has('advanced_analytics') ? 90 : 7),
    
    // Integration permissions
    canAccessAPI: has('api_access'),
    canUseWebhooks: has('api_access'),
    canUseSDK: has('api_access'),
    apiRateLimit: has('api_access') ? 10000 : 0,
    
    // Branding permissions
    canCustomizeBranding: has('5_templates') || has('unlimited_templates'),
    canWhiteLabel: has('white_label'),
    canUploadLogo: has('5_templates') || has('unlimited_templates'),
    canCustomDomains: has('custom_domains'),
    canCustomCSS: has('white_label'),
    maxLogoSize: has('unlimited_templates') ? '10MB' : (has('5_templates') ? '2MB' : '0MB'),
    
    // Export permissions
    canExportQR: has('5_templates') || has('unlimited_templates'),
    canBulkDownload: has('5_templates') || has('unlimited_templates'),
    canEmailDelivery: has('unlimited_templates'),
    canScheduleExports: has('unlimited_templates'),
    exportFormats: getExportFormats(has),
    
    // Support permissions
    supportLevel: has('unlimited_templates') ? 'priority' : (has('5_templates') ? 'email' : 'community'),
    canContactSupport: has('5_templates') || has('unlimited_templates'),
    canScheduleCalls: has('unlimited_templates')
  }
  
  return {
    isLoading: false,
    permissions,
    plan,
    hasFeature: (feature: ClerkFeature) => has(feature),
    user
  }
}

function getPlanFromFeatures(has: (feature: string) => boolean): 'starter' | 'business' | 'professional' {
  if (has('unlimited_templates')) return 'professional'
  if (has('5_templates')) return 'business'
  return 'starter'
}

function getExportFormats(has: (feature: string) => boolean): string[] {
  if (has('unlimited_templates')) {
    return ['PNG', 'SVG', 'PDF', 'EPS', 'CSV', 'Excel', 'JSON']
  }
  if (has('5_templates')) {
    return ['PNG', 'SVG', 'CSV']
  }
  return []
}
```

### 2. Billing Integration Hook
```typescript
// hooks/useBilling.ts
import { useUser } from '@clerk/nextjs'
import { useRouter } from 'next/navigation'

export function useBilling() {
  const { user } = useUser()
  const router = useRouter()
  const permissions = usePermissions()
  
  const createCheckoutSession = async (plan: 'business' | 'professional') => {
    if (!user) {
      router.push('/sign-in')
      return
    }
    
    try {
      const response = await fetch('/api/billing/create-checkout', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          priceId: STRIPE_PRODUCTS[plan].priceId,
          userId: user.id,
          userEmail: user.emailAddresses[0]?.emailAddress
        })
      })
      
      const { url } = await response.json()
      
      if (url) {
        // Track upgrade attempt
        analytics.track('checkout_initiated', {
          plan,
          from_plan: permissions.plan,
          user_id: user.id
        })
        
        window.location.href = url
      }
    } catch (error) {
      console.error('Failed to create checkout session:', error)
      toast.error('Failed to start checkout. Please try again.')
    }
  }
  
  const manageBilling = async () => {
    if (!user) return
    
    try {
      const response = await fetch('/api/billing/portal', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          userId: user.id
        })
      })
      
      const { url } = await response.json()
      
      if (url) {
        window.location.href = url
      }
    } catch (error) {
      console.error('Failed to access billing portal:', error)
      toast.error('Failed to access billing portal. Please try again.')
    }
  }
  
  const getUpgradeUrl = (targetPlan: 'business' | 'professional') => {
    return `/billing?plan=${targetPlan}`
  }
  
  const getPlanPrice = (plan: 'business' | 'professional') => {
    const product = STRIPE_PRODUCTS[plan]
    return {
      amount: product.price / 100,
      currency: product.currency.toUpperCase(),
      interval: product.interval
    }
  }
  
  return {
    createCheckoutSession,
    manageBilling,
    getUpgradeUrl,
    getPlanPrice,
    currentPlan: permissions.plan,
    isLoading: permissions.isLoading
  }
}
```

## 🔧 Billing API Routes

### 1. Create Checkout Session
```typescript
// app/api/billing/create-checkout/route.ts
import { NextRequest, NextResponse } from 'next/server'
import { auth } from '@clerk/nextjs'
import Stripe from 'stripe'

const stripe = new Stripe(process.env.STRIPE_SECRET_KEY!, {
  apiVersion: '2023-10-16'
})

export async function POST(request: NextRequest) {
  try {
    const { userId } = auth()
    
    if (!userId) {
      return NextResponse.json({ error: 'Unauthorized' }, { status: 401 })
    }
    
    const { priceId, userEmail } = await request.json()
    
    // Create Stripe checkout session
    const session = await stripe.checkout.sessions.create({
      customer_email: userEmail,
      line_items: [
        {
          price: priceId,
          quantity: 1
        }
      ],
      mode: 'subscription',
      success_url: `${process.env.NEXT_PUBLIC_APP_URL}/billing/success?session_id={CHECKOUT_SESSION_ID}`,
      cancel_url: `${process.env.NEXT_PUBLIC_APP_URL}/billing?cancelled=true`,
      metadata: {
        userId,
        clerkUserId: userId
      },
      subscription_data: {
        metadata: {
          userId,
          clerkUserId: userId
        }
      }
    })
    
    return NextResponse.json({ url: session.url })
    
  } catch (error) {
    console.error('Checkout session creation failed:', error)
    return NextResponse.json(
      { error: 'Failed to create checkout session' },
      { status: 500 }
    )
  }
}
```

### 2. Stripe Webhook Handler
```typescript
// app/api/billing/webhook/route.ts
import { NextRequest, NextResponse } from 'next/server'
import { clerkClient } from '@clerk/nextjs/server'
import Stripe from 'stripe'

const stripe = new Stripe(process.env.STRIPE_SECRET_KEY!, {
  apiVersion: '2023-10-16'
})

export async function POST(request: NextRequest) {
  const body = await request.text()
  const signature = request.headers.get('stripe-signature')!
  
  let event: Stripe.Event
  
  try {
    event = stripe.webhooks.constructEvent(
      body,
      signature,
      process.env.STRIPE_WEBHOOK_SECRET!
    )
  } catch (error) {
    console.error('Webhook signature verification failed:', error)
    return NextResponse.json({ error: 'Invalid signature' }, { status: 400 })
  }
  
  try {
    switch (event.type) {
      case 'checkout.session.completed':
        await handleCheckoutCompleted(event.data.object as Stripe.Checkout.Session)
        break
        
      case 'customer.subscription.updated':
        await handleSubscriptionUpdated(event.data.object as Stripe.Subscription)
        break
        
      case 'customer.subscription.deleted':
        await handleSubscriptionCancelled(event.data.object as Stripe.Subscription)
        break
        
      case 'invoice.payment_failed':
        await handlePaymentFailed(event.data.object as Stripe.Invoice)
        break
    }
    
    return NextResponse.json({ received: true })
    
  } catch (error) {
    console.error('Webhook handling failed:', error)
    return NextResponse.json(
      { error: 'Webhook handling failed' },
      { status: 500 }
    )
  }
}

async function handleCheckoutCompleted(session: Stripe.Checkout.Session) {
  const userId = session.metadata?.userId
  if (!userId) return
  
  const subscription = await stripe.subscriptions.retrieve(session.subscription as string)
  const priceId = subscription.items.data[0]?.price.id
  
  // Determine plan from price ID
  const plan = Object.entries(STRIPE_PRODUCTS).find(
    ([_, product]) => product.priceId === priceId
  )?.[0] as 'business' | 'professional'
  
  if (!plan) return
  
  // Add feature gates to Clerk user
  const features = STRIPE_PRODUCTS[plan].features
  
  for (const feature of features) {
    await clerkClient.users.updateUserMetadata(userId, {
      publicMetadata: {
        ...((await clerkClient.users.getUser(userId)).publicMetadata),
        [`feature_${feature}`]: true
      }
    })
  }
  
  // Store subscription in database
  await db.query(`
    INSERT INTO user_subscriptions (
      user_id, plan_id, stripe_subscription_id, status,
      current_period_start, current_period_end
    ) VALUES ($1, $2, $3, $4, $5, $6)
    ON CONFLICT (user_id) DO UPDATE SET
      plan_id = $2,
      stripe_subscription_id = $3,
      status = $4,
      current_period_start = $5,
      current_period_end = $6,
      updated_at = NOW()
  `, [
    userId,
    plan,
    subscription.id,
    subscription.status,
    new Date(subscription.current_period_start * 1000),
    new Date(subscription.current_period_end * 1000)
  ])
  
  // Track successful upgrade
  analytics.track('subscription_created', {
    user_id: userId,
    plan,
    price_id: priceId,
    subscription_id: subscription.id
  })
}

async function handleSubscriptionCancelled(subscription: Stripe.Subscription) {
  const userId = subscription.metadata?.userId
  if (!userId) return
  
  // Remove all feature gates from Clerk user
  const user = await clerkClient.users.getUser(userId)
  const metadata = { ...user.publicMetadata }
  
  // Remove all feature_ prefixed metadata
  Object.keys(metadata).forEach(key => {
    if (key.startsWith('feature_')) {
      delete metadata[key]
    }
  })
  
  await clerkClient.users.updateUserMetadata(userId, {
    publicMetadata: metadata
  })
  
  // Update subscription status in database
  await db.query(`
    UPDATE user_subscriptions 
    SET status = 'cancelled', updated_at = NOW()
    WHERE user_id = $1
  `, [userId])
  
  // Track cancellation
  analytics.track('subscription_cancelled', {
    user_id: userId,
    subscription_id: subscription.id
  })
}
```

## 📱 Billing Components

### 1. Plan Comparison Component
```tsx
// components/billing/PlanComparison.tsx
export function PlanComparison() {
  const { createCheckoutSession, currentPlan } = useBilling()
  const permissions = usePermissions()
  
  const plans = [
    {
      id: 'starter',
      name: 'Starter',
      price: 'Free',
      description: 'Perfect for getting started',
      features: [
        '1 Template',
        '50 QR codes/month',
        'Basic analytics (7 days)',
        'Community support'
      ],
      current: currentPlan === 'starter'
    },
    {
      id: 'business',
      name: 'Business',
      price: '€5.99/month',
      description: 'Great for small businesses',
      features: [
        '5 Templates',
        '1,000 QR codes/month',
        'Bulk generation (50)',
        'Advanced analytics (90 days)',
        'Email support',
        'Custom branding'
      ],
      current: currentPlan === 'business',
      popular: true
    },
    {
      id: 'professional',
      name: 'Professional',
      price: '€16.99/month',
      description: 'For power users and agencies',
      features: [
        'Unlimited Templates',
        'Unlimited QR codes',
        'Bulk generation (1,000)',
        'Full analytics history',
        'API Access',
        'White label',
        'Custom domains',
        'Priority support'
      ],
      current: currentPlan === 'professional'
    }
  ]
  
  return (
    <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
      {plans.map((plan) => (
        <Card key={plan.id} className={cn(
          "relative p-6",
          plan.popular && "border-blue-500 scale-105",
          plan.current && "border-green-500"
        )}>
          {plan.popular && (
            <Badge className="absolute -top-2 left-1/2 transform -translate-x-1/2 bg-blue-500">
              Most Popular
            </Badge>
          )}
          
          {plan.current && (
            <Badge className="absolute -top-2 right-4 bg-green-500">
              Current Plan
            </Badge>
          )}
          
          <div className="text-center">
            <h3 className="text-xl font-bold">{plan.name}</h3>
            <p className="text-gray-600 mt-2">{plan.description}</p>
            <div className="text-3xl font-bold mt-4">{plan.price}</div>
          </div>
          
          <ul className="mt-6 space-y-2">
            {plan.features.map((feature, index) => (
              <li key={index} className="flex items-center gap-2">
                <CheckIcon className="h-4 w-4 text-green-500" />
                <span className="text-sm">{feature}</span>
              </li>
            ))}
          </ul>
          
          <div className="mt-6">
            {plan.current ? (
              <Button variant="outline" className="w-full" disabled>
                Current Plan
              </Button>
            ) : plan.id === 'starter' ? (
              <Button variant="outline" className="w-full" disabled>
                Free Forever
              </Button>
            ) : (
              <Button 
                className="w-full" 
                onClick={() => createCheckoutSession(plan.id as 'business' | 'professional')}
              >
                Upgrade to {plan.name}
              </Button>
            )}
          </div>
        </Card>
      ))}
    </div>
  )
}
