# QR Platby SK - Backend Permission Validation & Enforcement

## 🔐 Server-Side Permission Architecture

### 1. Permission Middleware
```typescript
// middleware/permissions.ts
export function withPermissions(permissions: string[]) {
  return async function(req: NextRequest, res: NextResponse, next: NextFunction) {
    const user = await getUser(req)
    
    if (!user) {
      return NextResponse.json({ error: 'Unauthorized' }, { status: 401 })
    }
    
    const hasPermissions = await Promise.all(
      permissions.map(permission => checkUserPermission(user.id, permission))
    )
    
    if (!hasPermissions.every(Boolean)) {
      return NextResponse.json({ 
        error: 'Insufficient permissions',
        required: permissions,
        upgrade_url: getUpgradeUrl(user.plan, permissions)
      }, { status: 403 })
    }
    
    next()
  }
}

// Usage in API routes
export const POST = withPermissions(['can_create_template'])(
  async function handler(req: NextRequest) {
    // Template creation logic
  }
)
```

### 2. Usage Validation Middleware
```typescript
// middleware/usage-limits.ts
export function withUsageLimit(
  resource: string, 
  limitKey: string,
  increment: number = 1
) {
  return async function(req: NextRequest, res: NextResponse, next: NextFunction) {
    const user = await getUser(req)
    const currentUsage = await getCurrentUsage(user.id, resource)
    const limit = await getUserLimit(user.id, limitKey)
    
    if (limit !== -1 && currentUsage + increment > limit) {
      const plan = await getUserPlan(user.id)
      const upgradeTarget = getUpgradeTargetForLimit(plan, limitKey)
      
      return NextResponse.json({
        error: 'Usage limit exceeded',
        current: currentUsage,
        limit,
        resource,
        upgrade_target: upgradeTarget,
        upgrade_url: getUpgradeUrl(plan, [limitKey])
      }, { status: 429 })
    }
    
    // Increment usage after successful validation
    await incrementUsage(user.id, resource, increment)
    
    next()
  }
}

// Usage example
export const POST = withUsageLimit('qr_codes', 'monthly_qr_limit')(
  withPermissions(['can_generate_qr'])(
    async function generateQR(req: NextRequest) {
      // QR generation logic
    }
  )
)
```

## 📊 Database Schema for Permissions

### 1. User Plan Tracking
```sql
-- User subscription tracking
CREATE TABLE user_subscriptions (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id VARCHAR NOT NULL UNIQUE,
  plan_id VARCHAR NOT NULL DEFAULT 'starter',
  stripe_subscription_id VARCHAR,
  status VARCHAR NOT NULL DEFAULT 'active',
  current_period_start TIMESTAMP WITH TIME ZONE,
  current_period_end TIMESTAMP WITH TIME ZONE,
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Plan configurations
CREATE TABLE subscription_plans (
  id VARCHAR PRIMARY KEY,
  name VARCHAR NOT NULL,
  price_cents INTEGER NOT NULL,
  currency VARCHAR(3) NOT NULL DEFAULT 'EUR',
  interval VARCHAR NOT NULL, -- 'month' | 'year' | 'forever'
  features JSONB NOT NULL,
  limits JSONB NOT NULL,
  active BOOLEAN DEFAULT true,
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);
```

### 2. Usage Tracking Tables
```sql
-- Track usage across different resources
CREATE TABLE user_usage (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id VARCHAR NOT NULL,
  resource VARCHAR NOT NULL, -- 'templates', 'qr_codes', 'api_calls', etc.
  period VARCHAR NOT NULL,   -- 'daily', 'monthly', 'hourly'
  period_start TIMESTAMP WITH TIME ZONE NOT NULL,
  current_count INTEGER NOT NULL DEFAULT 0,
  max_count INTEGER, -- null = unlimited
  
  UNIQUE(user_id, resource, period, period_start)
);

-- Detailed usage logs for analytics
CREATE TABLE usage_logs (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id VARCHAR NOT NULL,
  resource VARCHAR NOT NULL,
  action VARCHAR NOT NULL,
  metadata JSONB,
  ip_address INET,
  user_agent TEXT,
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Indexes for performance
CREATE INDEX idx_user_usage_lookup ON user_usage(user_id, resource, period, period_start);
CREATE INDEX idx_usage_logs_user_time ON usage_logs(user_id, created_at);
```

## 🚀 Backend Permission Services

### 1. Permission Service
```typescript
// services/PermissionService.ts
export class PermissionService {
  static async checkPermission(
    userId: string, 
    permission: string
  ): Promise<boolean> {
    const userPlan = await this.getUserPlan(userId)
    const planConfig = await this.getPlanConfig(userPlan)
    
    return planConfig.permissions[permission] === true
  }
  
  static async checkUsageLimit(
    userId: string,
    resource: string,
    increment: number = 1
  ): Promise<{ allowed: boolean; current: number; limit: number; remaining: number }> {
    const userPlan = await this.getUserPlan(userId)
    const planConfig = await this.getPlanConfig(userPlan)
    const limit = planConfig.limits[resource] || 0
    
    if (limit === -1) {
      return { allowed: true, current: 0, limit: -1, remaining: -1 }
    }
    
    const currentUsage = await this.getCurrentUsage(userId, resource)
    const newUsage = currentUsage + increment
    const allowed = newUsage <= limit
    const remaining = Math.max(0, limit - newUsage)
    
    return { allowed, current: currentUsage, limit, remaining }
  }
  
  static async incrementUsage(
    userId: string,
    resource: string,
    amount: number = 1,
    metadata?: any
  ): Promise<void> {
    const period = this.getPeriodForResource(resource)
    const periodStart = this.getPeriodStart(period)
    
    // Upsert usage record
    await db.query(`
      INSERT INTO user_usage (user_id, resource, period, period_start, current_count)
      VALUES ($1, $2, $3, $4, $5)
      ON CONFLICT (user_id, resource, period, period_start)
      DO UPDATE SET 
        current_count = user_usage.current_count + $5,
        updated_at = NOW()
    `, [userId, resource, period, periodStart, amount])
    
    // Log the usage
    await db.query(`
      INSERT INTO usage_logs (user_id, resource, action, metadata)
      VALUES ($1, $2, 'increment', $3)
    `, [userId, resource, JSON.stringify({ amount, ...metadata })])
  }
  
  private static async getUserPlan(userId: string): Promise<string> {
    const result = await db.query(
      'SELECT plan_id FROM user_subscriptions WHERE user_id = $1 AND status = $2',
      [userId, 'active']
    )
    
    return result.rows[0]?.plan_id || 'starter'
  }
  
  private static async getCurrentUsage(
    userId: string, 
    resource: string
  ): Promise<number> {
    const period = this.getPeriodForResource(resource)
    const periodStart = this.getPeriodStart(period)
    
    const result = await db.query(`
      SELECT current_count FROM user_usage 
      WHERE user_id = $1 AND resource = $2 AND period = $3 AND period_start = $4
    `, [userId, resource, period, periodStart])
    
    return result.rows[0]?.current_count || 0
  }
}
```

### 2. API Route Validators
```typescript
// lib/api-validators.ts
export async function validateTemplateCreation(userId: string) {
  const canCreate = await PermissionService.checkPermission(userId, 'can_create_template')
  if (!canCreate) {
    throw new APIError('Template creation not available in your plan', 403, 'PERMISSION_DENIED')
  }
  
  const usageCheck = await PermissionService.checkUsageLimit(userId, 'templates', 1)
  if (!usageCheck.allowed) {
    throw new APIError(
      `Template limit reached: ${usageCheck.current}/${usageCheck.limit}`,
      429,
      'USAGE_LIMIT_EXCEEDED',
      { 
        current: usageCheck.current, 
        limit: usageCheck.limit,
        upgrade_target: getUpgradeTarget(await PermissionService.getUserPlan(userId), 'templates')
      }
    )
  }
  
  return usageCheck
}

export async function validateQRGeneration(userId: string, count: number = 1) {
  const canGenerate = await PermissionService.checkPermission(userId, 'can_generate_qr')
  if (!canGenerate) {
    throw new APIError('QR generation not available', 403, 'PERMISSION_DENIED')
  }
  
  const usageCheck = await PermissionService.checkUsageLimit(userId, 'qr_codes', count)
  if (!usageCheck.allowed) {
    const userPlan = await PermissionService.getUserPlan(userId)
    throw new APIError(
      `Monthly QR limit exceeded: ${usageCheck.current}/${usageCheck.limit}`,
      429,
      'USAGE_LIMIT_EXCEEDED',
      {
        current: usageCheck.current,
        limit: usageCheck.limit,
        requested: count,
        upgrade_target: getUpgradeTarget(userPlan, 'qr_codes')
      }
    )
  }
  
  return usageCheck
}

export async function validateBulkGeneration(userId: string, count: number) {
  const canBulk = await PermissionService.checkPermission(userId, 'bulk_generation')
  if (!canBulk) {
    throw new APIError('Bulk generation not available in your plan', 403, 'PERMISSION_DENIED')
  }
  
  const userPlan = await PermissionService.getUserPlan(userId)
  const planConfig = await PermissionService.getPlanConfig(userPlan)
  const maxBulkSize = planConfig.limits.max_bulk_size
  
  if (count > maxBulkSize) {
    throw new APIError(
      `Bulk size exceeds limit: ${count}/${maxBulkSize}`,
      400,
      'BULK_SIZE_EXCEEDED',
      { requested: count, max: maxBulkSize }
    )
  }
  
  return await validateQRGeneration(userId, count)
}
```

## 🔧 API Route Examples

### 1. Template Creation Endpoint
```typescript
// app/api/templates/route.ts
export async function POST(request: NextRequest) {
  try {
    const user = await getUser(request)
    if (!user) {
      return NextResponse.json({ error: 'Unauthorized' }, { status: 401 })
    }
    
    // Validate permissions and usage
    const usageCheck = await validateTemplateCreation(user.id)
    
    const body = await request.json()
    const templateData = templateCreateSchema.parse(body)
    
    // Create template
    const template = await createTemplate({
      ...templateData,
      userId: user.id
    })
    
    // Track usage
    await PermissionService.incrementUsage(user.id, 'templates', 1, {
      template_id: template.id,
      template_type: templateData.type
    })
    
    return NextResponse.json({
      template,
      usage: {
        current: usageCheck.current + 1,
        limit: usageCheck.limit,
        remaining: usageCheck.remaining - 1
      }
    })
    
  } catch (error) {
    if (error instanceof APIError) {
      return NextResponse.json({
        error: error.message,
        code: error.code,
        details: error.details
      }, { status: error.statusCode })
    }
    
    console.error('Template creation error:', error)
    return NextResponse.json(
      { error: 'Internal server error' },
      { status: 500 }
    )
  }
}
```

### 2. QR Generation Endpoint
```typescript
// app/api/qr/generate/route.ts
export async function POST(request: NextRequest) {
  try {
    const user = await getUser(request)
    if (!user) {
      return NextResponse.json({ error: 'Unauthorized' }, { status: 401 })
    }
    
    const body = await request.json()
    const { templateId, count = 1, bulk = false } = qrGenerateSchema.parse(body)
    
    // Validate based on generation type
    if (bulk && count > 1) {
      await validateBulkGeneration(user.id, count)
    } else {
      await validateQRGeneration(user.id, count)
    }
    
    // Generate QR codes
    const qrCodes = await generateQRCodes({
      templateId,
      count,
      userId: user.id
    })
    
    // Track usage
    await PermissionService.incrementUsage(user.id, 'qr_codes', count, {
      template_id: templateId,
      generation_type: bulk ? 'bulk' : 'single',
      count
    })
    
    const newUsage = await PermissionService.getCurrentUsage(user.id, 'qr_codes')
    const limit = await PermissionService.getUserLimit(user.id, 'monthly_qr_limit')
    
    return NextResponse.json({
      qr_codes: qrCodes,
      usage: {
        current: newUsage,
        limit,
        remaining: limit === -1 ? -1 : Math.max(0, limit - newUsage)
      }
    })
    
  } catch (error) {
    return handleAPIError(error)
  }
}
```

### 3. API Access Endpoint
```typescript
// app/api/v1/qr/route.ts - Public API for Professional users
export async function POST(request: NextRequest) {
  try {
    // API Key authentication
    const apiKey = request.headers.get('x-api-key')
    const user = await getUserByAPIKey(apiKey)
    
    if (!user) {
      return NextResponse.json({ error: 'Invalid API key' }, { status: 401 })
    }
    
    // Check API access permission
    const hasAPIAccess = await PermissionService.checkPermission(user.id, 'api_access')
    if (!hasAPIAccess) {
      return NextResponse.json({
        error: 'API access not available in your plan',
        upgrade_url: `/billing?plan=professional`
      }, { status: 403 })
    }
    
    // Check API rate limits
    const rateLimit = await checkAPIRateLimit(user.id)
    if (!rateLimit.allowed) {
      return NextResponse.json({
        error: 'API rate limit exceeded',
        limit: rateLimit.limit,
        reset_time: rateLimit.resetTime
      }, { status: 429 })
    }
    
    // Process API request
    const body = await request.json()
    const result = await processAPIRequest(user.id, body)
    
    // Track API usage
    await PermissionService.incrementUsage(user.id, 'api_calls', 1, {
      endpoint: '/api/v1/qr',
      ip: request.ip
    })
    
    return NextResponse.json(result)
    
  } catch (error) {
    return handleAPIError(error)
  }
}
```

## 📈 Usage Analytics & Monitoring

### 1. Usage Analytics Service
```typescript
// services/UsageAnalyticsService.ts
export class UsageAnalyticsService {
  static async getUserUsageStats(userId: string, days: number = 30) {
    const result = await db.query(`
      SELECT 
        resource,
        DATE(created_at) as date,
        COUNT(*) as count
      FROM usage_logs 
      WHERE user_id = $1 
        AND created_at >= NOW() - INTERVAL '${days} days'
      GROUP BY resource, DATE(created_at)
      ORDER BY date DESC
    `, [userId])
    
    return result.rows
  }
  
  static async getPlanUsageDistribution() {
    const result = await db.query(`
      SELECT 
        s.plan_id,
        COUNT(DISTINCT ul.user_id) as active_users,
        SUM(CASE WHEN ul.resource = 'qr_codes' THEN 1 ELSE 0 END) as total_qr_codes,
        SUM(CASE WHEN ul.resource = 'templates' THEN 1 ELSE 0 END) as total_templates
      FROM usage_logs ul
      JOIN user_subscriptions s ON ul.user_id = s.user_id
      WHERE ul.created_at >= NOW() - INTERVAL '30 days'
      GROUP BY s.plan_id
    `)
    
    return result.rows
  }
}
```

