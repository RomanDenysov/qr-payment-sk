## 🔒 Permission Hook Patterns

### 1. usePermissions Hook
```typescript
export function usePermissions() {
  const { has } = useHas() // Clerk hook
  const { user } = useUser()
  
  const permissions = useMemo(() => ({
    // Template permissions
    canCreateTemplate: has('5_templates') || has('unlimited_templates'),
    canDuplicateTemplate: has('5_templates') || has('unlimited_templates'),
    canShareTemplate: has('5_templates') || has('unlimited_templates'),
    canCollaborateTemplate: has('unlimited_templates'),
    
    // QR Generation permissions
    canBulkGenerate: has('bulk_generation'),
    canScheduleGeneration: has('unlimited_qr'),
    canCustomizeQR: has('5_templates') || has('unlimited_templates'),
    canGenerateDynamic: has('5_templates') || has('unlimited_templates'),
    
    // Analytics permissions
    canViewDetailedStats: has('advanced_analytics'),
    canExportAnalytics: has('advanced_analytics'),
    canCreateReports: has('unlimited_templates'),
    canScheduleReports: has('unlimited_templates'),
    canSetupAlerts: has('unlimited_templates'),
    
    // Integration permissions
    canAccessAPI: has('api_access'),
    canUseWebhooks: has('api_access'),
    canUseSDK: has('api_access'),
    
    // Branding permissions
    canCustomizeBranding: has('5_templates') || has('unlimited_templates'),
    canWhiteLabel: has('white_label'),
    canUploadLogo: has('5_templates') || has('unlimited_templates'),
    canCustomDomains: has('white_label'),
    canCustomCSS: has('white_label'),
    
    // Export permissions
    canExportQR: has('5_templates') || has('unlimited_templates'),
    canBulkDownload: has('5_templates') || has('unlimited_templates'),
    canEmailDelivery: has('unlimited_templates'),
    canScheduleExports: has('unlimited_templates')
  }), [has])
  
  return permissions
}
```

### 2. useUsageTracking Hook
```typescript
export function useUsageTracking(resource: string) {
  const { user } = useUser()
  const [usage, setUsage] = useState<UsageData | null>(null)
  const [loading, setLoading] = useState(true)
  
  useEffect(() => {
    if (!user?.id) return
    
    fetchUsageData(user.id, resource)
      .then(setUsage)
      .finally(() => setLoading(false))
  }, [user?.id, resource])
  
  const isLimitReached = usage && usage.limit !== -1 && usage.current >= usage.limit
  const isNearLimit = usage && usage.limit !== -1 && usage.current / usage.limit >= 0.8
  const remaining = usage?.limit === -1 ? Infinity : Math.max(0, (usage?.limit || 0) - (usage?.current || 0))
  
  return {
    usage,
    loading,
    isLimitReached,
    isNearLimit,
    remaining,
    refetch: () => fetchUsageData(user?.id!, resource).then(setUsage)
  }
}
```

### 3. useUpgradeFlow Hook
```typescript
export function useUpgradeFlow() {
  const { user } = useUser()
  const router = useRouter()
  
  const getCurrentPlan = () => {
    if (user?.has?.('unlimited_templates')) return 'professional'
    if (user?.has?.('5_templates')) return 'business'
    return 'starter'
  }
  
  const getUpgradeTarget = (feature: string) => {
    const currentPlan = getCurrentPlan()
    
    // Define feature -> plan mapping
    const featurePlanMap: Record<string, 'business' | 'professional'> = {
      'bulk_generation': 'business',
      'advanced_analytics': 'business',
      'api_access': 'professional',
      'white_label': 'professional',
      'custom_domains': 'professional'
    }
    
    const requiredPlan = featurePlanMap[feature]
    
    if (currentPlan === 'starter' && requiredPlan) {
      return requiredPlan
    }
    
    if (currentPlan === 'business' && requiredPlan === 'professional') {
      return 'professional'
    }
    
    return null
  }
  
  const initiateUpgrade = (targetPlan: 'business' | 'professional') => {
    // Track upgrade attempt
    analytics.track('upgrade_initiated', {
      from_plan: getCurrentPlan(),
      to_plan: targetPlan,
      source: 'permission_gate'
    })
    
    // Redirect to billing page
    router.push(`/billing?plan=${targetPlan}`)
  }
  
  return {
    currentPlan: getCurrentPlan(),
    getUpgradeTarget,
    initiateUpgrade
  }
}
```

## 🎯 Component Implementation Examples

### 1. Template Creation with Permission Gate
```typescript
function CreateTemplateButton() {
  const permissions = usePermissions()
  const { usage, isLimitReached } = useUsageTracking('templates')
  const { getUpgradeTarget, initiateUpgrade } = useUpgradeFlow()
  
  if (!permissions.canCreateTemplate || isLimitReached) {
    const targetPlan = getUpgradeTarget('template_creation')
    
    return (
      <UpgradePrompt
        targetPlan={targetPlan || 'business'}
        feature="Template Creation"
        currentUsage={usage?.current}
        limit={usage?.limit}
        onUpgrade={() => initiateUpgrade(targetPlan || 'business')}
      />
    )
  }
  
  return <Button onClick={createTemplate}>Create Template</Button>
}
```

