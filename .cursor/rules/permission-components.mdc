### 3. API Access Component
```tsx
function APIAccessPanel() {
  const permissions = usePermissions()
  const { usage } = useUsageTracking('api_calls')
  
  if (!permissions.canAccessAPI) {
    return (
      <Card className="p-6">
        <div className="flex items-center gap-4">
          <CodeIcon className="h-8 w-8 text-gray-400" />
          <div>
            <h3 className="text-lg font-medium">API Access</h3>
            <p className="text-sm text-gray-500">
              Integrate QR generation into your applications
            </p>
          </div>
        </div>
        <div className="mt-4">
          <UpgradePrompt 
            targetPlan="professional"
            feature="API Access"
            variant="banner"
          />
        </div>
      </Card>
    )
  }
  
  return (
    <Card className="p-6">
      <div className="flex items-center justify-between">
        <div className="flex items-center gap-4">
          <CodeIcon className="h-8 w-8 text-green-500" />
          <div>
            <h3 className="text-lg font-medium">API Access</h3>
            <p className="text-sm text-gray-500">
              {usage && (
                <span>
                  {usage.current.toLocaleString()} / {usage.limit === -1 ? '∞' : usage.limit.toLocaleString()} calls this hour
                </span>
              )}
            </p>
          </div>
        </div>
        <Button variant="outline" onClick={() => router.push('/api-docs')}>
          View Documentation
        </Button>
      </div>
      
      {usage && usage.limit !== -1 && (
        <div className="mt-4">
          <UsageIndicator
            resource="api_calls"
            current={usage.current}
            limit={usage.limit}
            period="hourly"
            variant="progress"
          />
        </div>
      )}
    </Card>
  )
}
```

