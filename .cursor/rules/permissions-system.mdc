## 🎯 Implementation Guidelines

### Clerk Feature Gates Setup
```typescript
// Define in Clerk Dashboard
const CLERK_FEATURES = {
  // Template limits
  '5_templates': 'business',
  'unlimited_templates': 'professional',
  
  // QR Generation
  '1000_qr_monthly': 'business',
  'unlimited_qr': 'professional',
  'bulk_generation': 'business,professional',
  
  // Advanced features
  'advanced_analytics': 'business,professional',
  'api_access': 'professional',
  'white_label': 'professional',
  'custom_domains': 'professional'
} as const
```

### Permission Validation Pattern
```typescript
// Backend validation helper
export async function validatePermission(
  userId: string,
  permission: keyof AllPermissions,
  value?: any
): Promise<boolean> {
  const userPlan = await getUserPlan(userId)
  const permissions = getPermissionsForPlan(userPlan)
  
  if (typeof permissions[permission] === 'boolean') {
    return permissions[permission] as boolean
  }
  
  if (typeof permissions[permission] === 'number') {
    const limit = permissions[permission] as number
    return limit === -1 || value <= limit
  }
  
  return false
}
```

### Frontend Permission Hooks
```typescript
// Custom hook for permission checking
export function usePermissions() {
  const { has } = useHas()
  const { user } = useUser()
  
  return {
    canCreateTemplate: has('5_templates') || has('unlimited_templates'),
    canBulkGenerate: has('bulk_generation'),
    canAccessAPI: has('api_access'),
    canWhiteLabel: has('white_label'),
    hasAdvancedAnalytics: has('advanced_analytics')
  }
}
```

